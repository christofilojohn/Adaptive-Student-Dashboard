# Adaptive Dashboard — environment configuration
# Copy to .env and edit as needed:  cp .env.example .env

# ── Model ────────────────────────────────────────────────────
# Override the local model cache directory (default: ~/.cache/dashboard-models)
# DASHBOARD_MODEL_DIR=/data/models

# ── LLM server ───────────────────────────────────────────────
# Token context window (default: 4096)
# LLM_CONTEXT=4096

# CPU threads for inference (default: 4, auto-set to 8 for CPU-only mode)
# LLM_THREADS=4

# GPU layers offloaded to VRAM (default: 999 = all)
# Set to 0 to force CPU mode
# LLM_NGL=999

# ── Ports ────────────────────────────────────────────────────
# (native start.sh only — edit start.sh directly for port changes)
# LLM_PORT=8080
# UI_PORT=5173

# ── AMD ROCm (Docker only) ───────────────────────────────────
# Required if your AMD GPU isn't auto-detected. Common values:
#   RX 6000 series → 10.3.0
#   RX 7000 series → 11.0.0
# HSA_OVERRIDE_GFX_VERSION=10.3.0

# ── Docker model directory ───────────────────────────────────
# Host path mounted as /models in the container (default: ./models)
# MODEL_DIR=./models

# ─────────────────────────────────────────────────────────────
# Adaptive Dashboard — Environment Configuration
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Model ─────────────────────────────────────────────────────
# Absolute path to the directory containing your .gguf model file.
# Used by start.sh (DASHBOARD_MODEL_DIR) and docker-compose (MODEL_DIR).
DASHBOARD_MODEL_DIR=~/.cache/dashboard-models
MODEL_DIR=./models

# ── LLM Server ────────────────────────────────────────────────
# Context window size (tokens). 4096 is a safe default.
LLM_CONTEXT=4096

# Number of CPU threads for llama-server inference.
LLM_THREADS=4

# Number of layers to offload to GPU.
# Set to 999 to offload all layers (recommended for NVIDIA/Apple Silicon).
# Set to 0 to run entirely on CPU.
LLM_NGL=999

# ── AMD ROCm only ─────────────────────────────────────────────
# Override the GFX version for unsupported AMD GPUs.
# Find yours with: rocminfo | grep gfx
# Example: HSA_OVERRIDE_GFX_VERSION=10.3.0  (for RX 6xxx series)
# HSA_OVERRIDE_GFX_VERSION=

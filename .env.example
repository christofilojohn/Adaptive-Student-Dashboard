# ─────────────────────────────────────────────────────────────
# Adaptive Dashboard — Environment Configuration
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Model ─────────────────────────────────────────────────────
# Absolute path to the directory containing your .gguf model file.
# DASHBOARD_MODEL_DIR  — used by start.sh (native mode)
# MODEL_DIR            — used by docker-compose
DASHBOARD_MODEL_DIR=~/.cache/dashboard-models
MODEL_DIR=./models

# ── LLM Server (Docker Compose + start.sh) ────────────────────
# These variables are read by both docker-compose and start.sh.

# Context window size (tokens). 4096 is a safe default.
LLM_CONTEXT=4096

# Number of CPU threads for llama-server inference.
LLM_THREADS=4

# Number of layers to offload to GPU.
# Set to 999 to offload all layers (recommended for NVIDIA/Apple Silicon).
# Set to 0 to run entirely on CPU.
LLM_NGL=999

# ── Frontend proxy port (native / start.sh mode only) ─────────
# Must match LLM_PORT in start.sh (default: 8080).
# Only needed if you change LLM_PORT from its default.
# VITE_LLM_PORT=8080
#
# Chat mode for Study Copilot:
# - zhipu (default, recommended for deployment)
# - local (uses /v1/chat/completions from local llama-server)
# VITE_CHAT_DEFAULT_MODE=zhipu
# Set false to hide/disable Local mode in UI (Zhipu-only deployment):
# VITE_CHAT_ALLOW_LOCAL=false
# Optional frontend hint for chat model name used in Zhipu mode:
# VITE_ZHIPU_CHAT_MODEL=glm-4-flash

# ── AMD ROCm only ─────────────────────────────────────────────
# Override the GFX version for unsupported AMD GPUs.
# Find yours with: rocminfo | grep gfx
# Example: HSA_OVERRIDE_GFX_VERSION=10.3.0  (for RX 6xxx series)
# HSA_OVERRIDE_GFX_VERSION=

# ── Gmail → Tasks Sync (optional) ────────────────────────────
# Uses backend/search-server.mjs endpoint: POST /search/gmail-tasks-sync
# to read recent Gmail messages and extract actionable tasks via Zhipu AI.
#
# 1) Zhipu API key (required for task extraction)
# ZHIPU_API_KEY=
# Optional model override (default: glm-4-flash)
# ZHIPU_MODEL=glm-4-flash
#
# 2) Gmail auth (choose one method)
# A) Direct short-lived access token:
# GMAIL_ACCESS_TOKEN=
#
# B) OAuth refresh token flow (recommended for long-term local use):
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# Optional fixed recipient for generated test emails:
# GMAIL_TEST_TO=you@example.com
#
# Optional Gmail query and fetch size:
# GMAIL_QUERY=newer_than:7d -category:promotions -category:social
# GMAIL_MAX_RESULTS=12
#
# Optional local Gmail cache (stored in ./data/dashboard.sqlite table gmail_cache)
# GMAIL_LIST_CACHE_TTL_MS=120000
# GMAIL_DETAIL_CACHE_TTL_MS=600000
# GMAIL_CACHE_MAX_BYTES=786432

# ── Local file database (SQLite) ────────────────────────────
# Dashboard state is saved in a local SQLite file by search-server.mjs.
# Default path: ./data/dashboard.sqlite
# DASHBOARD_DB_PATH=./data/dashboard.sqlite
# Optional DB directory shortcut (ignored if DASHBOARD_DB_PATH is set)
# DASHBOARD_DB_DIR=./data
#
# Max JSON payload sizes (bytes)
# SEARCH_MAX_BODY_BYTES=1048576
# DASHBOARD_STATE_MAX_BYTES=524288
